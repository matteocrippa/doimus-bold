{
  "name": "doimus-bold",
  "version": "0.2.0",
  "description": "Doimus plugin for Bold Smart Locks",
  "license": "MIT",
  "author": "Matteo Crippa",
  "main": "index.js",
  "doimus": {
    "type": "native",
    "oauth": {
      "authorization_url": "https://stefannienhuis.github.io/homebridge-bold/",
